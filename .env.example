# GCP deployment configuration — copy to .env and fill in your values.
# .env is listed in .gitignore and will NOT be committed.

GCP_PROJECT_ID=your-project-id
GCP_PROJECT_NUMBER=000000000000
GCP_REGION=asia-northeast1
GCP_ARTIFACT_REGISTRY=asia-northeast1-docker.pkg.dev
GCP_REGISTRY_REPO=slm-stack
